{{<layouts/default}}
{{$content}}
<section class="note-auth">
  <h1 class="hero-title">Password reset</h1>

  <div class="note-info" role="note">
    <p>登録済みのメールアドレスを入力してください。パスワードリセット用のリンクを送信します。</p>
  </div>

  {{#sent}}
  <div class="note-alert note-alert-success" role="status">
    パスワードリセットリンクを送信しました。メールを確認して、届いたリンクから新しいパスワードを設定してください。
  </div>
  {{/sent}}
  {{#error}}
  <div class="note-alert note-alert-error" role="alert">{{.}}</div>
  {{/error}}

  <form class="note-login-form" method="post" action="/note/password_reset/send_link" hx-boost="false">
    <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
    <div class="note-field">
      <label for="email">メールアドレス</label>
      <input id="email" name="email" type="email" autocomplete="email" value="{{email}}" required>
    </div>
    <button type="submit" class="note-submit">リセットリンクを送信</button>
  </form>

  <p class="note-auth-foot">
    <a href="/note/login">ログインに戻る</a>
  </p>
</section>
{{/content}}
{{/layouts/default}}
