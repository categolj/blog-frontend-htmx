{{<layouts/default}}
{{$content}}
<section class="note-auth">
  <h1 class="hero-title">Password reset</h1>

  <div class="note-info" role="note">
    <p>新しいパスワードを入力してください。再設定後はログイン画面からアクセスしてください。</p>
  </div>

  {{#error}}
  <div class="note-alert note-alert-error" role="alert">{{.}}</div>
  {{/error}}

  <form class="note-login-form" method="post" action="/note/password_reset/{{resetId}}" hx-boost="false">
    <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
    <div class="note-field">
      <label for="password">新しいパスワード</label>
      <input id="password" name="password" type="password" autocomplete="new-password" required>
    </div>
    <div class="note-field">
      <label for="confirmPassword">新しいパスワード (確認)</label>
      <input id="confirmPassword" name="confirmPassword" type="password" autocomplete="new-password" required>
    </div>
    <button type="submit" class="note-submit">パスワードを再設定する</button>
  </form>

  <p class="note-auth-foot">
    <a href="/note/login">ログインに戻る</a>
  </p>
</section>
{{/content}}
{{/layouts/default}}
