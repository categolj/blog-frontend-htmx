<section class="error-page not-translated" aria-labelledby="not-translated-title">
  <p class="not-translated-badge" aria-hidden="true">
    <svg class="not-translated-icon" aria-hidden="true"><use href="{{#src}}/img/icons.svg{{/src}}#globe-thin"/></svg>
    <span class="error-status not-translated-code">EN</span>
  </p>
  <h1 id="not-translated-title" class="error-title">Not Translated</h1>
  <p class="error-sub">Sorry, this entry is not yet translated into English.</p>
  <p class="not-translated-cta">
    <a class="btn not-translated-ja-link" href="{{jaUrl}}">
      <span class="not-translated-ja-label">Read the Japanese version</span>
      <span class="not-translated-ja-title">{{jaTitle}}</span>
    </a>
  </p>
  <p class="error-sub not-translated-footnote">
    You can also <a href="{{issueUrl}}" target="_blank" rel="noopener">request a translation</a>.
  </p>
</section>
