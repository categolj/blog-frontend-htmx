<div class="more-wrap">
  {{#nextUrl}}
    <a class="read-more-btn"
       href="{{{.}}}"
       hx-get="{{{.}}}"
       hx-target="closest .more-wrap"
       hx-swap="outerHTML">
      <span>Load more</span>
      <span class="read-more-arrow" aria-hidden="true">↓</span>
      <span class="read-more-spinner" aria-hidden="true"></span>
    </a>
  {{/nextUrl}}
</div>
